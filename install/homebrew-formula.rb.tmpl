# Homebrew formula for the lore CLI.
# Auto-generated by update-homebrew.yml — do not edit by hand.
#
# To install:
#   brew tap Gasmanc/lore
#   brew install lore

class Lore < Formula
  desc "Local documentation server for AI coding assistants"
  homepage "https://github.com/Gasmanc/lore"
  version "${VERSION}"
  license "MIT"

  on_macos do
    on_arm do
      url "https://github.com/Gasmanc/lore/releases/download/v${VERSION}/lore-v${VERSION}-aarch64-apple-darwin.tar.gz"
      sha256 "${AARCH64_MACOS}"
    end

    on_intel do
      url "https://github.com/Gasmanc/lore/releases/download/v${VERSION}/lore-v${VERSION}-x86_64-apple-darwin.tar.gz"
      sha256 "${X86_64_MACOS}"
    end
  end

  on_linux do
    on_arm do
      # aarch64-linux binary is not yet available; install via cargo instead:
      #   cargo install lore-cli
      odie "Pre-built aarch64 Linux binary not available yet. Install with: cargo install lore-cli"
    end

    on_intel do
      url "https://github.com/Gasmanc/lore/releases/download/v${VERSION}/lore-v${VERSION}-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "${X86_64_LINUX}"
    end
  end

  def install
    bin.install "lore"
  end

  def caveats
    <<~EOS
      The first time lore downloads a package it will fetch the bge-small-en-v1.5
      embedding model (~130 MB) and cache it in:
        ~/.cache/lore/models/

      To get started, add a documentation package:
        lore add tokio

      Then configure your AI assistant to use the MCP server:
        lore mcp
    EOS
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/lore --version")
  end
end
